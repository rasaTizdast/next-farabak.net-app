generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["blog", "info", "member", "project", "support", "company_activity", "contact_us", "farabak_net_technomi", "landing_page"]
}

// Updated product model
// Updated Password model
// Updated Master_ProductOverviewDetails
// Updated Details_ProductOverviewDetails
// Updated Invoice and InvoiveDetails

model BlogCategories {
  id          Int        @id(map: "PK__BlogCate__3213E83F00BCAE91") @default(autoincrement())
  blog_id     Int
  category_id Int
  Blogs       Blogs      @relation(fields: [blog_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK__BlogCateg__blog___270FB757")
  Categories  Categories @relation(fields: [category_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK__BlogCateg__categ__2803DB90")

  @@schema("blog")
}

model Blogs {
  id                Int              @id(map: "PK__Blogs__3213E83F77E508B6") @default(autoincrement())
  title             String           @db.VarChar(255)
  SEO_Title         String           @db.VarChar(70)
  slug              String           @unique(map: "UQ__Blogs__32DD1E4C6CC87B20") @db.VarChar(255)
  created_at        String?          @db.VarChar(50)
  status            String           @default("Draft") @db.VarChar(50)
  views_count       Int              @default(0)
  content           String
  author            String?          @db.VarChar(100)
  SEO_description   String           @db.VarChar(165)
  image_URL         String           @default("") @db.VarChar(2500)
  image_alt         String           @default("") @db.VarChar(250)
  QrCode_key        String?          @db.VarChar(100)
  QrCode_expiryDays String?          @db.VarChar(50)
  BlogCategories    BlogCategories[]
  Comments          Blog_Comments[]
  Likes             Likes[]
  BlogFAQs          BlogFAQs[]

  @@schema("blog")
}

model Categories {
  id             Int              @id(map: "PK__Categori__3213E83FF119B6A9") @default(autoincrement())
  name           String?          @db.VarChar(100)
  slug           String?          @unique(map: "UQ__Categori__32DD1E4C6F98CBB2") @db.VarChar(100)
  BlogCategories BlogCategories[]

  @@schema("blog")
}

model Blog_Comments {
  id         Int     @id(map: "PK__Comments__3213E83F1557248B") @default(autoincrement())
  blog_id    Int
  content    String
  created_at String? @db.VarChar(50)
  Blogs      Blogs   @relation(fields: [blog_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK__Comments__blog_i__2AE0483B")

  @@map("Comments")
  @@schema("blog")
}

model Likes {
  id         Int     @id(map: "PK__Likes__3213E83F50D1E341") @default(autoincrement())
  blog_id    Int
  created_at String? @db.VarChar(50)
  Blogs      Blogs   @relation(fields: [blog_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK__Likes__blog_id__33758E3C")

  @@schema("blog")
}

model Client {
  UserID            Int        @id(map: "PK__Client__1788CCAC14357FE4") @default(autoincrement())
  Username          String?    @db.VarChar(30)
  FirstName         String?    @db.VarChar(30)
  LastName          String?    @db.VarChar(30)
  PhoneNumber       String?    @db.VarChar(11)
  Email             String?    @db.VarChar(50)
  City              String?    @db.VarChar(20)
  Job               String?    @db.VarChar(30)
  Role              String?    @default("Public") @db.VarChar(50)
  ActivePhoneNumber Boolean?
  ActiveEmail       Boolean?
  Password          Password[]
  branch            branch[]

  @@schema("info")
}

model FaqDetails {
  FaqDetailsid Int       @id(map: "PK__FaqDetai__35A141347E7D7444") @default(autoincrement())
  Q            String?   @db.VarChar(1000)
  A            String?   @db.VarChar(3000)
  Available    Boolean?
  InsertDate   DateTime? @default(now()) @db.Timestamp(6)
  ModifyDate   DateTime? @default(now()) @db.Timestamp(6)

  @@schema("info")
}

model Invoice {
  Invoiceid       Int               @id(map: "PK__Invoice__D7C667ED9E33565E") @default(autoincrement())
  FactorGuid      String?           @db.VarChar(1000)
  Fullname        String?           @db.VarChar(200)
  Phonenumber     String?           @db.VarChar(11)
  UserId          Int?
  TotalAmount     Float?
  Checked         Boolean?
  Date            String?           @db.VarChar(50)
  Invoice_Details Invoice_Details[]

  @@schema("info")
}

model Invoice_Details {
  Invoice_Details Int        @id(map: "PK__Invoice___4A16C8C534ABC2CC") @default(autoincrement())
  Invoiceid       Int?
  UserId          Int?
  ProductId       Int?
  quantity        Float?
  price           Float?
  total_price     Float?
  Invoice         Invoice?   @relation(fields: [Invoiceid], references: [Invoiceid])
  warranty        warranty[]

  @@schema("info")
}

model Password {
  PasswordId Int      @id(map: "PK__Password__EA7BF0C8D7AEEB79") @default(autoincrement())
  Password1  String?  @db.VarChar(4000)
  UserId     Int?
  Active     Boolean?

  // new added field
  Client Client? @relation(fields: [UserId], references: [UserID])

  @@schema("info")
}

model SMS_Status {
  SMSID        Int       @id(map: "PK__SMS_Stat__244A5CBB4CCA8300") @default(autoincrement())
  From         String?   @db.VarChar(200)
  TO           String?   @db.VarChar(200)
  Text         String?   @db.VarChar(200)
  Value        String?   @db.VarChar(200)
  Retstatus    Int?
  StrRetstatus String?   @db.VarChar(200)
  InsertDate   DateTime? @default(now()) @db.Timestamp(6)
  ModifyDate   DateTime? @default(now()) @db.Timestamp(6)

  @@schema("info")
}

model Members {
  Membersid        Int     @id(map: "PK__Members__5456DC83F7FEAB42") @default(autoincrement()) @db.SmallInt
  main_pic         String  @db.VarChar(200)
  Name             String  @db.VarChar(20)
  Role             String  @db.VarChar(20)
  main_description String  @db.VarChar(4000)
  Slug             String  @unique @db.VarChar(500)
  phonenumber      String? @db.VarChar(11)

  @@schema("member")
}

model ProjectMedia {
  MediaID   Int      @id(map: "PK__ProjectM__B2C2B5AFD34F46E7") @default(autoincrement())
  ProjectID Int
  MediaType String?  @db.VarChar(20)
  MediaURL  String
  Projects  Projects @relation(fields: [ProjectID], references: [ProjectID], onDelete: Cascade, onUpdate: NoAction, map: "FK__ProjectMe__Proje__4D35603F")

  @@schema("project")
}

model Projects {
  ProjectID    Int            @id(map: "PK__Projects__761ABED095EDE184") @default(autoincrement())
  Title        String         @db.VarChar(255)
  Description  String
  Slug         String         @db.VarChar(255)
  IsActive     Boolean
  Main_img_URL String         @db.VarChar(500)
  date         String         @db.VarChar(100)
  city         String         @db.VarChar(100)
  ProjectMedia ProjectMedia[]

  @@schema("project")
}

model Category {
  CategoryID       Int               @id(map: "PK__Category__19093A2B5BDCB8F5") @default(autoincrement())
  Name             String?           @db.VarChar(1000)
  Available        Boolean?
  InsertDate       DateTime?         @default(now()) @db.Timestamp(6)
  ModifyDate       DateTime?         @default(now()) @db.Timestamp(6)
  Category_groupId Int?
  Slug             String?           @db.VarChar(200)
  Banner           String?           @db.VarChar(4000)
  // SEO/AEO/AIO blogs for category pages
  TopBlog          String?           @db.Text
  BottomBlog       String?           @db.Text
  CategoryContent  CategoryContent[]
  SEO_Category     SEO_Category?
  Product          Product[]

  @@schema("support")
}

model CategoryContent {
  CategoryContentId   Int                  @id(map: "PK_CategoryContent") @default(autoincrement())
  Name                String?              @db.VarChar(200)
  CategoryID          Int?
  Slug                String?              @db.VarChar(200)
  Available           Boolean?
  InsertDate          DateTime?            @default(now()) @db.Timestamp(6)
  ModifyDate          DateTime?            @default(now()) @db.Timestamp(6)
  Banner              String?              @db.VarChar(4000)
  // SEO/AEO/AIO blogs for subcategory pages
  TopBlog             String?              @db.Text
  BottomBlog          String?              @db.Text
  Category            Category?            @relation(fields: [CategoryID], references: [CategoryID], onDelete: NoAction, onUpdate: NoAction, map: "FK_CategoryContent_Category_CategoryID")
  SEO_CategoryContent SEO_CategoryContent?

  @@schema("support")
}

model Details_ProductOverviewDetails {
  id                       Int     @id(map: "PK__Master_P__3213E83FCDAEB8AB") @unique(map: "UQ_ProductOverviewDetails_table_id") @default(autoincrement())
  ProductOverviewDetailsId Int?
  productid                Int?
  ProductName              String? @db.VarChar(255)

  // Added item
  Master_ProductOverviewDetails Master_ProductOverviewDetails? @relation(fields: [ProductOverviewDetailsId], references: [ProductOverviewDetailsId])

  @@schema("support")
}

model FAQs {
  FAQsId       Int       @id(map: "PK__FAQs__6DDBE835DC17F6BB") @default(autoincrement())
  Title        String?   @db.VarChar(1000)
  Description  String?   @db.VarChar(3000)
  FilesAddress String?   @db.VarChar(500)
  ProductId    Int?
  Available    Boolean?
  InsertDate   DateTime? @default(now()) @db.Timestamp(6)
  ModifyDate   DateTime? @default(now()) @db.Timestamp(6)

  @@schema("support")
}

model Master_ProductOverviewDetails {
  id                       Int    @id @default(autoincrement())
  ProductOverviewDetailsId Int?   @unique(map: "UQ_ProductOverviewDetailsId")
  Title                    String @db.VarChar(2000)
  Description              String @db.VarChar(4000)
  Img                      String @db.VarChar(1000)

  // Added item
  Details_ProductOverviewDetails Details_ProductOverviewDetails[]

  @@schema("support")
}

model Product {
  ProductId         Int      @id(map: "PK__Product__B40CC6CDE69145E5") @default(autoincrement())
  Name              String?  @db.VarChar(1000)
  Type              String?  @db.VarChar(100)
  Price             String?  @db.VarChar(20)
  Discount          String?  @db.VarChar(20)
  CategoryContentId String?  @db.VarChar(1000)
  img1              String?  @db.VarChar(500)
  img2              String?  @db.VarChar(500)
  Available         Boolean?
  Description       String?  @db.VarChar(1000)
  CategoryId        Int?
  Slug              String?  @db.VarChar(1200)
  SEO_Title         String?  @db.VarChar(60)
  SEO_Description   String?  @db.VarChar(4000)
  QrCode_Key        String?  @db.VarChar(100)
  QrCode_expiryDays String?  @db.VarChar(50)
  productBlog       String?
  Partner_Price     String?  @db.VarChar(20)

  // new added field
  Category         Category?          @relation(fields: [CategoryId], references: [CategoryID])
  branchproduct    branchproduct[]
  warehouseproduct warehouseproduct[]
  warranty         warranty[]
  ProductGrade     ProductGrade[]

  @@schema("support")
}

model ProductGrade {
  ProductGradeId Int      @id @default(autoincrement())
  ProductId      Int
  Grade          String   @db.VarChar(1)
  Price          Int
  discount       Int
  Product        Product? @relation(fields: [ProductId], references: [ProductId])

  @@map("ProductGrade")
  @@schema("support")
}

model ProductOverview {
  ProductOverviewId Int       @id(map: "PK__ProductO__2C6062D2C1D11FB4") @default(autoincrement())
  ProductName       String?   @db.VarChar(1200)
  ProductId         Int?
  Property1         String?   @db.VarChar(300)
  Property2         String?   @db.VarChar(300)
  Property3         String?   @db.VarChar(300)
  Property4         String?   @db.VarChar(300)
  Available         Boolean?
  InsertDate        DateTime? @default(now()) @db.Timestamp(6)
  ModifyDate        DateTime? @default(now()) @db.Timestamp(6)

  @@schema("support")
}

model ProductSpecs {
  ProductSpecsId Int       @id(map: "PK__ProductS__AD8D1EF57B85BAB5") @default(autoincrement())
  Name           String?   @db.VarChar(1000)
  Title          String?   @db.VarChar(1000)
  Description    String?   @db.VarChar(4000)
  ProductId      Int?
  Available      Boolean?
  InsertDate     DateTime? @default(now()) @db.Timestamp(6)
  ModifyDate     DateTime? @default(now()) @db.Timestamp(6)

  @@schema("support")
}

model SEO_Category {
  SEO_CategoryId  Int      @id(map: "PK__SEO_Cate__D6289EBC542C7D1C") @default(autoincrement())
  CategoryID      Int      @unique(map: "unique_categoryID")
  SEO_Title       String?  @db.VarChar(60)
  SEO_Description String?
  SEO_Keywords    String?  @db.VarChar(2000)
  Category        Category @relation(fields: [CategoryID], references: [CategoryID], onDelete: Cascade, onUpdate: NoAction, map: "FK__SEO_Categ__Categ__392E6792")

  @@schema("support")
}

model SEO_CategoryContent {
  SEO_CategoryContentId Int             @id(map: "PK__SEO_Cate__7D930FEB48C5431C") @default(autoincrement())
  CategoryContentId     Int             @unique(map: "unique_CategoryContentID")
  SEO_Title             String?         @db.VarChar(60)
  SEO_Description       String?
  SEO_Keywords          String?         @db.VarChar(2000)
  CategoryContent       CategoryContent @relation(fields: [CategoryContentId], references: [CategoryContentId], onDelete: Cascade, onUpdate: NoAction, map: "FK__SEO_Categ__Categ__43ABF605")

  @@schema("support")
}

model EFMigrationsHistory {
  MigrationId    String @id(map: "PK___EFMigrationsHistory1") @db.VarChar(150)
  ProductVersion String @db.VarChar(32)

  @@map("__EFMigrationsHistory")
  @@schema("farabak_net_technomi")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model Media {
  id         Int     @id @default(autoincrement())
  blog_id    Int
  media_type String  @db.VarChar(50)
  media_URL  String  @db.VarChar(2500)
  media_alt  String? @db.VarChar(250)

  @@schema("blog")
}

model BlogFAQs {
  id         Int     @id @default(autoincrement())
  blog_id    Int
  question   String  @db.VarChar(400)
  answer     String  @db.VarChar(1500)
  available  Boolean @default(true)
  created_at String  @db.VarChar(10)
  updated_at String  @db.VarChar(10)
  order      Int     @default(0)
  Blogs      Blogs   @relation(fields: [blog_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@schema("blog")
}

model Details_activity {
  id              Int             @id @default(autoincrement())
  activityID      Int
  description     String          @db.VarChar(400)
  Master_activity Master_activity @relation(fields: [activityID], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("company_activity")
}

model Master_activity {
  id               Int                @id(map: "master_activity_pkey") @default(autoincrement())
  title            String             @db.VarChar(90)
  Details_activity Details_activity[]

  @@schema("company_activity")
}

model address {
  id          Int    @id @default(autoincrement())
  address     String @db.VarChar(1000)
  postal_code Int
  alt_text    String @db.VarChar(150)

  @@schema("contact_us")
}

model emails {
  id      Int    @id @default(autoincrement())
  title   String @db.VarChar(50)
  address String @db.VarChar(320)

  @@schema("contact_us")
}

model phone_numbers {
  id     Int    @id @default(autoincrement())
  number String @db.VarChar(13)

  @@schema("contact_us")
}

model showcase_products {
  id          Int    @id @default(autoincrement())
  title       String @db.VarChar(90)
  description String @db.VarChar(160)
  order       Int    @unique
  image       String @db.VarChar(500)
  link        String @db.VarChar(1500)

  @@schema("landing_page")
}

model sliders {
  id        Int     @id @default(autoincrement())
  image_URL String  @db.VarChar(500)
  image_alt String? @db.VarChar(250)
  link      String  @db.VarChar(1500)

  @@schema("landing_page")
}

model branch {
  branchid      Int             @id @default(autoincrement())
  UserID        Int
  name          String          @unique @db.VarChar(255)
  location      String?         @db.VarChar(10)
  createdat     DateTime?       @default(now()) @db.Timestamp(6)
  Client        Client          @relation(fields: [UserID], references: [UserID], onDelete: Cascade, onUpdate: NoAction)
  branchproduct branchproduct[]
  warranty      warranty[]

  @@schema("support")
}

model branchproduct {
  branchproductid Int     @id @default(autoincrement())
  branchid        Int
  ProductId       Int
  quantity        Int?    @default(0)
  Product         Product @relation(fields: [ProductId], references: [ProductId], onDelete: Cascade, onUpdate: NoAction)
  branch          branch  @relation(fields: [branchid], references: [branchid], onDelete: Cascade, onUpdate: NoAction)

  @@schema("support")
}

model warehouse {
  warehouseid      Int                @id @default(autoincrement())
  name             String             @unique @db.VarChar(255)
  location         String?            @db.VarChar(255)
  createdat        DateTime?          @default(now()) @db.Timestamp(6)
  warehouseproduct warehouseproduct[]

  @@schema("support")
}

model warehouseproduct {
  warehouseproductid Int       @id @default(autoincrement())
  warehouseid        Int
  ProductId          Int
  quantity           Int?      @default(0)
  Product            Product   @relation(fields: [ProductId], references: [ProductId], onDelete: Cascade, onUpdate: NoAction)
  warehouse          warehouse @relation(fields: [warehouseid], references: [warehouseid], onDelete: Cascade, onUpdate: NoAction)

  @@schema("support")
}

model warranty {
  warrantyid      Int             @id @default(autoincrement())
  userid          Int
  invoicedetailid Int
  branchid        Int
  warrantycode    String          @unique @db.VarChar(1000)
  ProductId       Int
  startdate       String?         @db.VarChar(500)
  expirydate      String?         @db.VarChar(500)
  status          String?         @default("Active") @db.VarChar(50)
  Product         Product         @relation(fields: [ProductId], references: [ProductId], onDelete: Cascade, onUpdate: NoAction)
  branch          branch          @relation(fields: [branchid], references: [branchid], onDelete: Cascade, onUpdate: NoAction)
  Invoice_Details Invoice_Details @relation(fields: [invoicedetailid], references: [Invoice_Details], onDelete: Cascade, onUpdate: NoAction)

  @@schema("info")
}

model SpecTemplate {
  SpecTemplateId Int                @id @default(autoincrement())
  Name           String             @db.VarChar(100)
  InsertDate     DateTime           @default(now())
  ModifyDate     DateTime           @updatedAt
  Items          SpecTemplateItem[] // Relation

  @@map("SpecTemplate")
  @@schema("support")
}

model SpecTemplateItem {
  SpecTemplateItemId Int      @id @default(autoincrement())
  SpecTemplateId     Int
  Title              String   @db.VarChar(100)
  InsertDate         DateTime @default(now())
  ModifyDate         DateTime @updatedAt

  Template SpecTemplate @relation(fields: [SpecTemplateId], references: [SpecTemplateId], onDelete: Cascade)

  @@map("SpecTemplateItem")
  @@schema("support")
}
