generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["Blog", "Info", "Member", "Project", "Support", "farabak_net_technomi"]
}

// Updated product model
// Updated Password model
// Updated Master_ProductOverviewDetails
// Updated Details_ProductOverviewDetails

model BlogCategories {
  id          Int        @id(map: "PK__BlogCate__3213E83F00BCAE91") @default(autoincrement())
  blog_id     Int
  category_id Int
  Blogs       Blogs      @relation(fields: [blog_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK__BlogCateg__blog___270FB757")
  Categories  Categories @relation(fields: [category_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK__BlogCateg__categ__2803DB90")

  @@schema("Blog")
}

model BlogTags {
  id      Int   @id(map: "PK__BlogTags__3213E83F9FF48426") @default(autoincrement())
  blog_id Int
  tag_id  Int
  Blogs   Blogs @relation(fields: [blog_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK__BlogTags__blog_i__2FA4FD58")
  Tags    Tags  @relation(fields: [tag_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK__BlogTags__tag_id__30992191")

  @@schema("Blog")
}

model Blogs {
  id             Int              @id(map: "PK__Blogs__3213E83F77E508B6") @default(autoincrement())
  title          String?          @db.VarChar(255)
  SEO_Title      String?          @db.VarChar(255)
  slug           String?          @unique(map: "UQ__Blogs__32DD1E4C6CC87B20") @db.VarChar(255)
  file_url       String?          @db.VarChar(500)
  media_type     String?          @db.VarChar(50)
  created_at     String?          @db.VarChar(50)
  updated_at     String?          @db.VarChar(50)
  status         String?          @default("Draft") @db.VarChar(50)
  views_count    Int?             @default(0)
  BlogCategories BlogCategories[]
  BlogTags       BlogTags[]
  Comments       Blog_Comments[]
  Content        Content[]
  Likes          Likes[]

  @@schema("Blog")
}

model Categories {
  id             Int              @id(map: "PK__Categori__3213E83FF119B6A9") @default(autoincrement())
  name           String?          @db.VarChar(100)
  slug           String?          @unique(map: "UQ__Categori__32DD1E4C6F98CBB2") @db.VarChar(100)
  BlogCategories BlogCategories[]

  @@schema("Blog")
}

model Blog_Comments {
  id         Int     @id(map: "PK__Comments__3213E83F1557248B") @default(autoincrement())
  blog_id    Int
  content    String
  created_at String? @db.VarChar(50)
  Blogs      Blogs   @relation(fields: [blog_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK__Comments__blog_i__2AE0483B")

  @@map("Comments")
  @@schema("Blog")
}

model Content {
  id      Int    @id(map: "PK__Content__3213E83F772A2EF7") @default(autoincrement())
  content String @db.VarChar(4000)
  blog_id Int
  Blogs   Blogs  @relation(fields: [blog_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK__Content__blog_id__3651FAE7")

  @@schema("Blog")
}

model Likes {
  id         Int     @id(map: "PK__Likes__3213E83F50D1E341") @default(autoincrement())
  blog_id    Int
  created_at String? @db.VarChar(50)
  Blogs      Blogs   @relation(fields: [blog_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK__Likes__blog_id__33758E3C")

  @@schema("Blog")
}

model Tags {
  id       Int        @id(map: "PK__Tags__3213E83FCF9ADA1D") @default(autoincrement())
